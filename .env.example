# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit credentials or paths.

# Docker image tag
IMAGE_TAG=ida-vnc:9.4

# Container runtime settings
HOST_PORT=8443
VNC_PASSWORD=changeme

# Local paths for runtime mounts (absolute paths on the host)
# Absolute path to your IDA license file (ida.hexlic)
IDA_HEXLIC_HOST_PATH=/path/to/ida.hexlic

# Absolute path to a persistent workspace directory
# This will be mounted as /home/kasm-user/workspace inside the container
WORKSPACE_HOST_PATH=/path/to/IDA-workspace

# Absolute path to your IDA Pro installer (.run file)
# Default: downloads/ida-pro_94_x64linux.run (relative to project root)
IDA_INSTALLER=downloads/ida-pro_94_x64linux.run
