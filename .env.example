# Copy this file to .env and fill in your actual paths.
# .env is gitignored — never commit credentials or paths.

# Remote Builder host (SSH alias or IP)
BUILDER_HOST=your-builder-host

# Docker image tag
BUILDER_IMAGE_TAG=ida-vnc:9.4

# Container runtime settings
HOST_PORT=8443
VNC_PASSWORD=changeme

# ---- Builder-side paths (where your installer, license, and workspace live) ----
# Absolute path to your IDA Pro installer on the Builder host
# The installer must be the official x86-64 Linux .run file (e.g. ida-pro_94_x64linux.run)
IDA_INSTALLER_SRC=/path/to/ida-pro_94_x64linux.run

# Absolute path to your IDA license file (ida.hexlic) on the Builder host
IDA_HEXLIC_HOST_PATH=/path/to/ida.hexlic

# Absolute path to a persistent workspace directory on the Builder host
# This will be mounted as /home/kasm-user/workspace inside the container
WORKSPACE_HOST_PATH=/path/to/IDA-workspace
